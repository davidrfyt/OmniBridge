# 丘멆잺丘멆잺丘멆잺 IMPORTANT: RENAME THIS FILE TO .env 丘멆잺丘멆잺丘멆잺
# Port where the OmniBridge Web Interface will be hosted locally
WEB_PORT=8080

# The debugging port configured in Antigravity (usually 9222)
CDP_PORT=9222

# Security Credentials for the Web Interface
WEB_USERNAME=admin
WEB_PASSWORD=your_secure_password

# Debug flag for attachment upload and cloning logs (true/false)
DEBUG_UPLOADS=false
